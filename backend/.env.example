# Stroyka Tools Store — Environment Variables Reference
# Copy this file to .env and fill in your own values.
# This file is safe to commit. The actual .env is gitignored.

NODE_ENV=development

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=your_strong_random_secret_minimum_32_characters
JWT_EXPIRES_IN=24h

# ── bcrypt ────────────────────────────────────────────────────────────────────
# OWASP minimum = 10. Production recommendation = 12.
BCRYPT_SALT_ROUNDS=10

# ── SQLite Database ───────────────────────────────────────────────────────────
# Leave blank to use the default path (backend/store.db).
# For production, supply an absolute path outside the project folder.
DB_PATH=
